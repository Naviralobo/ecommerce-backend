const mongoose = require("mongoose");

const productSchema = new mongoose.Schema({
  id: {
    type: Number,
    required: true,
  },
  name: {
    type: String,
    required: [true, "Product name is required"],
  },
  description: {
    type: String,
    required: true,
  },
  price: {
    type: Number,
    required: true,
  },
  category: {
    type: String,
    required: true,
  },
  //   imageUrl: {
  //     type: String,
  //     required: true,
  //   },
  //it can be description:String format as well, but we are using object format to add validation and other properties
});

module.exports = mongoose.model("Product", productSchema);
