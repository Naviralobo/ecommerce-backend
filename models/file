const mongoose = require("mongoose");

const fileSchema = new mongoose.Schema(
  {
    url: { type: String },
    key: { type: String, required: true, unique: true },
    originalName: { type: String },
    mimeType: { type: String },
    size: { type: Number },
  },
  { timeStamps: true },
);

module.exports = mongoose.model("File", fileSchema);
